# =============================================================
# Backend Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================

# --- Local PostgreSQL ---
DATABASE_URL=jdbc:postgresql://localhost:5432/payroll_db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# --- Hosted PostgreSQL (Neon / Supabase / Railway) ---
# DATABASE_URL=jdbc:postgresql://ep-xxx.us-east-2.aws.neon.tech/payroll_db?sslmode=require
# DATABASE_USERNAME=your_db_user
# DATABASE_PASSWORD=your_db_password

# --- JWT Secret (must be at least 32 characters) ---
JWT_SECRET=my-super-secret-jwt-key-that-is-at-least-32-characters-long
